{
  "id": "cixio.infra.hooks.tfFmt",
  "name": "Terraform Formatter Sync",
  "event": "PostToolUse",
  "action": {
    "type": "shellExecution",
    "command": "terraform",
    "args": [
      "fmt",
      "-recursive",
      "terraform/"
    ],
    "options": {
      "env": {
        "TARGET_FILE": "${activeEditorFile}"
      }
    }
  },
  "timeout": 10000
}